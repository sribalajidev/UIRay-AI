    },
    "homepage": "https://github.com/sribalajidev/UIRay-AI#readme",
    "dependencies": {
      "@google/generative-ai": "^0.24.1",
      "dotenv": "^17.4.1",
      "inquirer": "^8.2.7",
      "minimist": "^1.2.8",
      "pixelmatch": "^7.1.0",
      "pngjs": "^7.0.0",
      "puppeteer": "^24.40.0"
    }
  }
